# Physical device / Expo Go on same Wi-Fi as your PC:
EXPO_PUBLIC_API_URL=http://192.168.1.8:3000

# iOS Simulator:
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Android Emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# USB only (requires adb reverse tcp:3000 tcp:3000):
# EXPO_PUBLIC_API_URL=http://localhost:3000
