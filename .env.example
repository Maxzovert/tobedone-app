# Production (Render, etc.)
EXPO_PUBLIC_API_URL=

# Local dev — comment out EXPO_PUBLIC_API_URL above, then the app auto-detects:
# - Physical device: same IP as Expo Metro (QR code host)
# - Android emulator: http://10.0.2.2:3000
# - iOS simulator: http://localhost:3000
#
# Manual LAN override if auto-detection fails:
# EXPO_PUBLIC_API_URL=http://192.168.29.183:3000
#
# If sign-in fails on a real phone against a local backend, run as Admin:
#   mobile/scripts/allow-api-firewall.ps1
