{
  "expo": {
    "name": "Tobedone",
    "slug": "tobedone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tobedone",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f6fa"
    },
    "androidStatusBar": {
      "backgroundColor": "#f4f6fa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tobedone.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4f6fa"
      },
      "package": "com.tobedone.app",
      "versionCode": 1,
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tobedone to access your photos to set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
